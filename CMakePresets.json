{
    "version": 5,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja Multi-Config",
            "cacheVariables": {
                "CMAKE_CONFIGURATION_TYPES": "Debug;Release;RelWithDebInfo",
                "CMAKE_EXPORT_COMPILE_COMMANDS": true,
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
            },
            "binaryDir": "build"
        },
        {
            "name": "base-clang",
            "hidden": true,
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_C_COMPILER": "clang"
            }
        },
        {
            "name": "msvc-config",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "cl",
                "CMAKE_C_COMPILER": "cl",
                "VCPKG_TARGET_TRIPLET" : "x64-windows",
                "VCPKG_HOST_TRIPLET" : "x64-windows"
            },
            "toolset": {
                "value": "v143"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "mingw-config",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_C_COMPILER": "gcc",
                "VCPKG_TARGET_TRIPLET" : "x64-mingw-dynamic",
                "VCPKG_HOST_TRIPLET" : "x64-mingw-dynamic"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "macos-arm64-config",
            "inherits": "base-clang",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET" : "arm64-osx",
                "VCPKG_HOST_TRIPLET" : "arm64-osx"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "macos-x64-config",
            "inherits": "base-clang",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET" : "x64-osx",
                "VCPKG_HOST_TRIPLET" : "x64-osx"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "build-debug",
            "hidden": true,
            "configuration": "Debug"
        },
        {
            "name": "build-release",
            "hidden": true,
            "configuration": "Release"
        },
        {
            "name": "build-relwithdebinfo",
            "hidden": true,
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "msvc-debug-build",
            "inherits": "build-debug",
            "configurePreset": "msvc-config"
        },
        {
            "name": "msvc-release-build",
            "inherits": "build-release",
            "configurePreset": "msvc-config"
        },
        {
            "name": "msvc-relwithdebinfo-build",
            "inherits": "build-relwithdebinfo",
            "configurePreset": "msvc-config"
        },
        {
            "name": "mingw-debug-build",
            "inherits": "build-debug",
            "configurePreset": "mingw-config"
        },
        {
            "name": "mingw-release-build",
            "inherits": "build-release",
            "configurePreset": "mingw-config"
        },
        {
            "name": "mingw-relwithdebinfo-build",
            "inherits": "build-relwithdebinfo",
            "configurePreset": "mingw-config"
        },
        {
            "name": "macos-arm64-debug-build",
            "inherits": "build-debug",
            "configurePreset": "macos-arm64-config"
        },
        {
            "name": "macos-arm64-release-build",
            "inherits": "build-release",
            "configurePreset": "macos-arm64-config"
        },
        {
            "name": "macos-arm64-relwithdebinfo-build",
            "inherits": "build-relwithdebinfo",
            "configurePreset": "macos-arm64-config"
        },
        {
            "name": "macos-x64-debug-build",
            "inherits": "build-debug",
            "configurePreset": "macos-x64-config"
        },
        {
            "name": "macos-x64-release-build",
            "inherits": "build-release",
            "configurePreset": "macos-x64-config"
        },
        {
            "name": "macos-x64-relwithdebinfo-build",
            "inherits": "build-relwithdebinfo",
            "configurePreset": "macos-x64-config"
        }
    ],
    "testPresets": [
        {
            "name": "test-debug",
            "hidden": true,
            "configuration": "Debug",
            "execution": 
            {
                "stopOnFailure": true
            }
        },
        {
            "name": "test-release",
            "hidden": true,
            "configuration": "Release",
            "execution": 
            {
                "stopOnFailure": true
            }
        },
        {
            "name": "test-relwithdebinfo",
            "hidden": true,
            "configuration": "RelWithDebInfo",
            "execution": 
            {
                "stopOnFailure": true
            }
        },
        {
            "name": "msvc-debug-test",
            "inherits": "test-debug",
            "configurePreset": "msvc-config"
        },
        {
            "name": "msvc-release-test",
            "inherits": "test-release",
            "configurePreset": "msvc-config"
        },
        {
            "name": "msvc-relwithdebinfo-test",
            "inherits": "test-relwithdebinfo",
            "configurePreset": "msvc-config"
        },
        {
            "name": "mingw-debug-test",
            "inherits": "test-debug",
            "configurePreset": "mingw-config"
        },
        {
            "name": "mingw-release-test",
            "inherits": "test-release",
            "configurePreset": "mingw-config"
        },
        {
            "name": "mingw-relwithdebinfo-test",
            "inherits": "test-relwithdebinfo",
            "configurePreset": "mingw-config"
        },
        {
            "name": "macos-arm64-debug-test",
            "inherits": "test-debug",
            "configurePreset": "macos-arm64-config"
        },
        {
            "name": "macos-arm64-release-test",
            "inherits": "test-release",
            "configurePreset": "macos-arm64-config"
        },
        {
            "name": "macos-arm64-relwithdebinfo-test",
            "inherits": "test-relwithdebinfo",
            "configurePreset": "macos-arm64-config"
        },
        {
            "name": "macos-x64-debug-test",
            "inherits": "test-debug",
            "configurePreset": "macos-x64-config"
        },
        {
            "name": "macos-x64-release-test",
            "inherits": "test-release",
            "configurePreset": "macos-x64-config"
        },
        {
            "name": "macos-x64-relwithdebinfo-test",
            "inherits": "test-relwithdebinfo",
            "configurePreset": "macos-x64-config"
        }
    ]
}